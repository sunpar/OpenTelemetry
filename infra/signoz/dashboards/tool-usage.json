{
  "schema_version": "agent-otel-trial.dashboard.v1",
  "title": "Tool Usage",
  "description": "Starter tool-call dashboard for cross-agent operational review.",
  "filters": [
    "telemetry.user.email",
    "telemetry.team.id",
    "agent.tool",
    "agent.capture.profile",
    "model.name",
    "run.outcome"
  ],
  "panels": [
    {
      "title": "Tool calls by user",
      "signal": "logs",
      "query": "count tool call events",
      "group_by": ["telemetry.user.email", "agent.tool"]
    },
    {
      "title": "Failed tool calls",
      "signal": "logs",
      "query": "count failed tool call events",
      "group_by": ["run.outcome", "agent.tool"]
    },
    {
      "title": "Slow tool calls",
      "signal": "traces",
      "query": "p95 tool execution span duration",
      "group_by": ["agent.tool"]
    },
    {
      "title": "Approval denials",
      "signal": "logs",
      "query": "count approval denial events",
      "group_by": ["telemetry.user.email", "agent.tool"]
    }
  ]
}
