# Non-secret local defaults for the Agent OpenTelemetry trial.
AOTEL_ENV=local
AOTEL_PUBLIC_ENDPOINT=http://localhost:8088

# Auth API.
AUTH_API_HOST=0.0.0.0
AUTH_API_PORT=8000
AUTH_API_DB_PATH=/data/auth-api.sqlite3

# Authenticated gateway ingress.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8088

# Internal OpenTelemetry routing.
OTEL_COLLECTOR_OTLP_HTTP_ENDPOINT=http://otel-collector:4318
SIGNOZ_OTLP_GRPC_ENDPOINT=signoz-otel-collector:4317

# Local Docker network names used by Compose tasks.
GATEWAY_NETWORK=agent-otel-gateway
SIGNOZ_NETWORK=signoz-net

# Local SigNoz checkout used by make signoz-up.
SIGNOZ_VENDOR_DIR=.vendor/signoz
