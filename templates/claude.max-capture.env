# Max capture can include prompt text, tool input/output, full API request and
# response bodies, and conversation history. Use only with short-lived tokens
# whose trusted capture profile is max.
export OTEL_LOG_USER_PROMPTS=1
export OTEL_LOG_TOOL_DETAILS=1
export OTEL_LOG_TOOL_CONTENT=1
export OTEL_LOG_RAW_API_BODIES=1
