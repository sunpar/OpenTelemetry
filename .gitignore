*.db
*.sqlite
*.sqlite3
services/auth-api/*.db
services/auth-api/*.sqlite
services/auth-api/*.sqlite3

# SigNoz, vendor, and local Compose output.
.vendor/
.signoz/
signoz-data/
data/signoz/
compose/signoz-data/
infra/signoz/data/
